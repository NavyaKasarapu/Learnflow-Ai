# =========================================================================
# LearnFlow AI - Universal Production Environment Variables Example
# Copy this file to .env and configure values before starting development.
# =========================================================================

# -------------------------------------------------------------------------
# 1. CORE & AI ENGINE CONFIGURATION (Universal)
# -------------------------------------------------------------------------
# Required for generating personalized syllabus maps and learning roadmaps.
GEMINI_API_KEY="AI_Studio_or_Google_AI_Studio_Gemini_API_Key"

# -------------------------------------------------------------------------
# 2. FULL-STACK NODE.JS (EXPRESS + REACT) SERVICE CONFIGURATION
# -------------------------------------------------------------------------
# Port for the Node.js Express Server (defaults to 3000 if omitted)
PORT=3000

# The JWT Secret used to sign and verify user authentication tokens (Express)
JWT_SECRET="generate_a_random_secure_secret_key_string"

# Node Env: set to 'production' on Render
NODE_ENV="production"

# Your Vercel frontend URL or client domain (to bypass CORS restrictions)
FRONTEND_URL="https://your-learnflow-frontend.vercel.app"

# -------------------------------------------------------------------------
# 3. ALTERNATIVE FASTAPI PYTHON BACKEND CONFIGURATION
# -------------------------------------------------------------------------
# Database Connection String for PostgreSQL (e.g. Render PostgreSQL Connection URI)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://user:password@localhost:5412/learnflow"

# Secret Key for JWT token encoding/decoding inside FastAPI
JWT_SECRET_KEY="generate_another_random_secure_secret_key_string"

# Encryption algorithm for Python JWT (commonly 'HS256')
JWT_ALGORITHM="HS256"
